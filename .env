# --- IMPOSTAZIONI DI PRECISIONE ---
# 
TEXT_THRESHOLD=0.05
OCR_CONFIDENCE_TRIGGER=0.85

# --- MODELLI OLLAMA ---
MODEL_SUPERVISOR="deepseek-r1:14b"
MODEL_VISION="llama3.2-vision:latest"

# --- SICUREZZA ---
ENABLE_SAFE_SAVE=True
# Se la soglia supera lo 0.08 (8%), il sistema mostrerà un disclaimer automatico.