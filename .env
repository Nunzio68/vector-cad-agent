# --- CORE OPERATIVO (MODELLI LOCALI) ---
# Modello per la Visione (Analisi JPG Impianto)
MODEL_VISION="llama3.2-vision:latest" 
# Modello per il Codice (Generazione DWG/DXF)
MODEL_CODER="qwen2.5-coder:14b-instruct-q4_K_M"
# Modello Supervisore (Logica e Tripla Scelta)
MODEL_SUPERVISOR="deepseek-r1:14b"

# --- OPZIONE CLOUD (SE ATTIVA) ---
# Se vuoi usare il cloud, scrivi qui il nome (es: minimax-m2.1:cloud)
MODEL_FALLBACK="minimax-m2.1:cloud"

# --- PARAMETRI DI PRECISIONE ---
TEXT_THRESHOLD=0.05
OCR_CONFIDENCE_TRIGGER=0.85
ENABLE_SAFE_SAVE=True

# --- CONFIGURAZIONE RETE ---
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"